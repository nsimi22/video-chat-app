{
  "expo": {
    "name": "Huddle",
    "slug": "huddle",
    "scheme": "huddle",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#0b0b0d",
    "primaryColor": "#5b8cff",
    "splash": {
      "backgroundColor": "#0b0b0d",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.huddle.app",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Huddle uses your camera for video calls.",
        "NSMicrophoneUsageDescription": "Huddle uses your microphone for calls.",
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "com.huddle.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MICROPHONE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        { "cameraPermission": "Huddle uses your camera for video calls." }
      ],
      "expo-notifications",
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "Huddle uses your camera for video calls.",
          "microphonePermission": "Huddle uses your microphone for calls."
        }
      ]
    ],
    "extra": {
      "supabaseUrl": "https://jwqvrdgjpftjiwvgdrck.supabase.co",
      "supabaseAnonKey": "sb_publishable_5eJWwJEHWHSLuhFEs2iUlw_tu4fGOvn",
      "eas": { "projectId": "" }
    }
  }
}
