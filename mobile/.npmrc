# Required because @livekit/react-native nests its own react-dom whose
# peer is react@^19.2.x while the rest of the tree (Expo SDK 54) pins
# react@19.1.0. The conflict is harmless at runtime (react-dom isn't
# used on RN). Try removing this and running `npm install` after any
# LiveKit or Expo bump to see if it's still needed.
legacy-peer-deps=true
