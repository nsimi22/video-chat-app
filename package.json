{
  "name": "video-chat-app",
  "version": "0.3.0",
  "description": "Desktop video + multi-screen-share + Slack-style chat, on Supabase",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "node scripts/copy-vendor.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.huddle.app",
    "productName": "Huddle",
    "directories": { "output": "dist", "buildResources": "build" },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "scripts/**/*",
      "package.json"
    ],
    "extraMetadata": { "main": "main.js" },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "artifactName": "Huddle-mac-${arch}.${ext}",
      "identity": null,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "artifactName": "Huddle-win-${arch}.${ext}"
    },
    "linux": {
      "category": "Network",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb", "arch": ["x64"] }
      ],
      "artifactName": "Huddle-linux-${arch}.${ext}"
    },
    "publish": [{ "provider": "github", "releaseType": "release" }]
  }
}
